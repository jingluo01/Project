# --- Flask Configuration ---
FLASK_ENV=development
SECRET_KEY=replace-with-a-very-long-and-random-string
JWT_SECRET_KEY=replace-with-a-very-long-and-random-string

# --- Database Configuration ---
# Format: mysql+pymysql://user:password@host:port/database
# For Local: use localhost
# For Docker: use mysql (as defined in docker-compose.yml)
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/campus_parking

# Extension: External School Member Database (Optional)
SCHOOL_DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/school_official

# --- Redis Configuration ---
# Format: redis://host:port/db_index
REDIS_URL=redis://localhost:6379/0

# --- CORS Configuration ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Alipay Configuration (Sandbox) ---
# APPID from Alipay Open Platform
ALIPAY_APPID=

# Your Application Private Key (PKCS8 format)
ALIPAY_PRIVATE_KEY=

# Alipay Public Key (NOT Application Public Key)
ALIPAY_PUBLIC_KEY=

# Gateway Address (Default is Sandbox)
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# Payment Success Return URL
ALIPAY_RETURN_URL=http://localhost:5173/payment/return
